<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:layout_width="match_parent" android:layout_height="?attr/actionBarSize"
            app:title="Ajustes" app:titleTextColor="@color/text_primary"
            app:subtitle="Activa los filtros que usas" app:subtitleTextColor="@color/text_secondary" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="FILTROS ACTIVOS" android:textColor="@color/accent_purple"
            android:textSize="11sp" android:textStyle="bold"
            android:layout_marginTop="8dp" android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="@color/surface_dark" app:cardCornerRadius="10dp"
            app:strokeColor="@color/border_dark" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="12dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="L-Pro"
                        android:textColor="@color/filter_lpro" android:textSize="13sp" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_lpro"
                        android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Ha — Askar C1"
                        android:textColor="@color/filter_ha" android:textSize="13sp" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_ha"
                        android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="OIII — Askar C2"
                        android:textColor="@color/filter_oiii" android:textSize="13sp" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_oiii"
                        android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="SII (Azufre)"
                        android:textColor="@color/accent_purple_light" android:textSize="13sp" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_sii"
                        android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="L-Extreme / Dual Band"
                        android:textColor="@color/accent_purple_light" android:textSize="13sp" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_lext"
                        android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="FILTROS PERSONALIZADOS" android:textColor="@color/accent_purple"
            android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface_dark" app:cardCornerRadius="10dp"
            app:strokeColor="@color/border_dark" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="12dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Filtro extra 1 activo"
                        android:textColor="@color/text_secondary" android:textSize="12sp" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_custom1"
                        android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="Nombre filtro extra 1"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/border_dark" app:hintTextColor="@color/text_secondary"
                    android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_custom1_name" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:inputType="text"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Filtro extra 2 activo"
                        android:textColor="@color/text_secondary" android:textSize="12sp" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_custom2"
                        android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="Nombre filtro extra 2"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/border_dark" app:hintTextColor="@color/text_secondary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_custom2_name" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:inputType="text"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        
        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_help"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp" android:layout_marginBottom="8dp"
            android:text="? Instrucciones de uso"
            app:strokeColor="@color/border_dark" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_save_settings"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="16dp" android:layout_marginBottom="24dp"
            android:text="Guardar ajustes" app:backgroundTint="@color/accent_purple" />

    </LinearLayout>
</ScrollView>
