<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp" android:layout_marginVertical="5dp"
    app:cardBackgroundColor="@color/surface_dark" app:cardCornerRadius="12dp"
    app:strokeColor="@color/border_dark" app:strokeWidth="1dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="14dp">

        <!-- Cabecera: nombre + estado -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">

                <TextView android:id="@+id/text_wish_object_name"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/text_primary" android:textSize="14sp"
                    android:textStyle="bold" />
                
                <LinearLayout 
            android:layout_width="wrap_content" 
            android:layout_height="wrap_content"
            android:orientation="horizontal" 
            android:layout_marginTop="2dp">

            <TextView android:id="@+id/indicator_m1" android:layout_width="22dp" android:layout_height="wrap_content"
                android:text="-" android:textSize="12sp" android:gravity="center" android:textColor="@color/accent_purple" android:textStyle="bold"/>
            <TextView android:id="@+id/indicator_m2" android:layout_width="22dp" android:layout_height="wrap_content"
                android:text="-" android:textSize="12sp" android:gravity="center" android:textColor="@color/accent_purple" android:textStyle="bold"/>
            <TextView android:id="@+id/indicator_m3" android:layout_width="22dp" android:layout_height="wrap_content"
                android:text="-" android:textSize="12sp" android:gravity="center" android:textColor="@color/accent_purple" android:textStyle="bold"/>
            <TextView android:id="@+id/indicator_m4" android:layout_width="22dp" android:layout_height="wrap_content"
                android:text="-" android:textSize="12sp" android:gravity="center" android:textColor="@color/accent_purple" android:textStyle="bold"/>
        </LinearLayout>

                <TextView android:id="@+id/text_wish_filter"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary" android:textSize="11sp"
                    android:layout_marginTop="2dp" />

                <TextView android:id="@+id/text_wish_visibility"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary" android:textSize="11sp"
                    android:layout_marginTop="2dp" />

                <TextView android:id="@+id/text_wish_ref"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/accent_purple_light" android:textSize="11sp"
                    android:layout_marginTop="3dp" android:visibility="gone" />
            </LinearLayout>

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_status"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Pendiente" android:textSize="11sp"
                app:chipMinHeight="28dp" />
        </LinearLayout>

        <!-- Botones -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="10dp"
            android:gravity="center_vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_edit"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Editar"
                android:textSize="12sp" app:strokeColor="@color/border_dark" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_alert"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="6dp"
                android:text="☆ Alerta" android:textSize="12sp"
                app:strokeColor="@color/border_dark" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_delete"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="6dp" android:text="✕"
                android:textSize="12sp" android:textColor="@color/error_color"
                app:strokeColor="@color/error_color" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
