<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="5dp"
    app:cardBackgroundColor="@color/surface_dark"
    app:cardCornerRadius="12dp"
    app:strokeColor="@color/border_dark"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Cabecera: número + nombre + badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/text_session_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/accent_purple"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingEnd="8dp" />

            <TextView
                android:id="@+id/text_object_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Fecha + condiciones -->
        <TextView
            android:id="@+id/text_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/text_conditions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <!-- Seeing dots -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical">

            <View android:id="@+id/dot1" android:layout_width="10dp" android:layout_height="10dp"
                android:layout_marginEnd="3dp" android:background="@drawable/seeing_dot" />
            <View android:id="@+id/dot2" android:layout_width="10dp" android:layout_height="10dp"
                android:layout_marginEnd="3dp" android:background="@drawable/seeing_dot" />
            <View android:id="@+id/dot3" android:layout_width="10dp" android:layout_height="10dp"
                android:layout_marginEnd="3dp" android:background="@drawable/seeing_dot" />
            <View android:id="@+id/dot4" android:layout_width="10dp" android:layout_height="10dp"
                android:layout_marginEnd="3dp" android:background="@drawable/seeing_dot" />
            <View android:id="@+id/dot5" android:layout_width="10dp" android:layout_height="10dp"
                android:background="@drawable/seeing_dot" />

        </LinearLayout>

        <!-- Divisor -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_dark"
            android:layout_marginVertical="8dp" />

        <!-- Filtros -->
        <TextView android:id="@+id/text_lpro"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/filter_lpro" android:textSize="12sp" />

        <TextView android:id="@+id/text_ha"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/filter_ha" android:textSize="12sp" android:layout_marginTop="2dp" />

        <TextView android:id="@+id/text_oiii"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/filter_oiii" android:textSize="12sp" android:layout_marginTop="2dp" />

        <!-- Total -->
        <TextView android:id="@+id/text_total"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/accent_purple_light"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="6dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
