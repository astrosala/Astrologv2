<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="16dp">

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Nombre del objeto"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="@color/border_dark" app:hintTextColor="@color/text_secondary">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edit_dialog_name"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:inputType="text" android:textColor="@color/text_primary" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Filtro principal"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="@color/border_dark" app:hintTextColor="@color/text_secondary"
        android:layout_marginTop="8dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edit_dialog_filter"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:inputType="text" android:textColor="@color/text_primary"
            android:hint="L-Pro / Askar C1 Hα / Askar C2 OIII" />
    </com.google.android.material.textfield.TextInputLayout>
</LinearLayout>
